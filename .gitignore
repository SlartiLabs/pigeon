# Python
__pycache__/
*.py[cod]
*.egg-info/
.eggs/
build/
dist/
.pytest_cache/
.venv/
venv/

# agentctx runtime artifacts (generated; the schema + config are tracked)
.pigeon/manifest.json
.pigeon/metrics.jsonl
.pigeon/routing_log.jsonl
.pigeon/handoffs/*.json
.pigeon/coordinate/
.pigeon/context/
.pigeon/adopt/
.pigeon/probe.json
.pigeon/ci/
# (.pigeon/memory/ is deliberately tracked: distilled session knowledge
#  is the part of the episodic log meant to survive a clone)

# Benchmark opsec: the private name<->label map and raw run logs never leave the
# machine (they carry real repo names + code paths). Only anonymized results ship.
docs/benchmarks/tier-a/private-map.json
docs/benchmarks/results/raw/

# Optional local vector store
.pigeon/vector/

# OS
.DS_Store

# coverage artifacts
.coverage
.coverage.*
htmlcov/

# Claude Code local (per-machine) permissions — never shared
.claude/settings.local.json
